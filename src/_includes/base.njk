<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or "Mobile1st — Digital Product Growth" }}</title>
  <meta name="description" content="{{ description or 'We run personalization and experimentation programs for e-commerce brands doing $5M–$100M online. Most clients see measurable RPV lift within 90 days.' }}" />
  <link rel="canonical" href="https://mobile1st.com{{ page.url }}" />
  <link rel="alternate" type="application/atom+xml" href="https://mobile1st.com/feed.xml" title="The E-Commerce Director's Cut" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="Mobile1st" />
  <meta property="og:title" content="{{ title or 'Mobile1st — Digital Product Growth' }}" />
  <meta property="og:description" content="{{ description or 'We run personalization and experimentation programs for e-commerce brands doing $5M–$100M online. Most clients see measurable RPV lift within 90 days.' }}" />
  <meta property="og:url" content="https://mobile1st.com{{ page.url }}" />
  <meta property="og:type" content="{% if date %}article{% else %}website{% endif %}" />
  <meta property="og:image" content="{{ og_image or 'https://mobile1st.com/img/og-default.png' }}" />
  {% if date %}<meta property="article:published_time" content="{{ date | htmlDateString }}" />{% endif %}
  {% if author %}<meta property="article:author" content="{{ author }}" />{% endif %}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title or 'Mobile1st — Digital Product Growth' }}" />
  <meta name="twitter:description" content="{{ description or 'We run personalization and experimentation programs for e-commerce brands doing $5M–$100M online. Most clients see measurable RPV lift within 90 days.' }}" />
  <meta name="twitter:image" content="{{ og_image or 'https://mobile1st.com/img/og-default.png' }}" />

  <!-- Organization schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Mobile1st",
    "url": "https://mobile1st.com",
    "logo": "https://mobile1st.com/img/logo.png",
    "description": "E-commerce optimization for Shopify brands doing $5M–$100M online. Personalization, experimentation, and smarter data.",
    "founder": { "@type": "Person", "name": "Justin Aronstein" },
    "contactPoint": { "@type": "ContactPoint", "email": "justin@mobile1st.com", "contactType": "customer service" }
  }
  </script>

  <!-- Poppins from Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!--
    Obviously font (OH no Type Co) — commercial license required.
    Purchase at: https://ohnotype.co/fonts/obviously
    After purchasing, place font files in src/fonts/ and uncomment the @font-face
    block in src/css/style.css
  -->

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" href="/img/favicon.ico" />

  <!-- Leadfeeder -->
  <script>(function(ss,ex){ window.ldfdr=window.ldfdr||function(){(ldfdr._q=ldfdr._q||[]).push([].slice.call(arguments));}; (function(d,s){ fs=d.getElementsByTagName(s)[0]; function ce(src){ var cs=d.createElement(s); cs.src=src; cs.async=1; fs.parentNode.insertBefore(cs,fs); }; ce('https://sc.lfeeder.com/lftracker_v1_'+ss+(ex?'_'+ex:'')+'.js'); })(document,'script'); })('p1e024BoolKaGB6d');</script>

  <!-- REB2B -->
  <script>
    !function(key) {
    if (window.reb2b) return;
    window.reb2b = {loaded: true};
    var s = document.createElement("script");
    s.async = true;
    s.src = "https://b2bjsstore.s3.us-west-2.amazonaws.com/b/" + key + "/" + key + ".js.gz";
    document.getElementsByTagName("script")[0].parentNode.insertBefore(s, document.getElementsByTagName("script")[0]);
}("Q1N5W0H9J7O5");
  </script>
</head>
<body>

  <header class="site-header">
    <div class="container">
      <a href="/" class="logo"><img src="/img/logo.png" alt="Mobile1st" height="48" /></a>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <nav class="site-nav">
        <a href="/#what-we-do">What We Do</a>
        <a href="/#products">Products</a>
        <a href="/#results">Results</a>
        <a href="/news/">Director's Cut</a>
        <a href="https://podcast.mobile1st.com" target="_blank" rel="noopener">Podcast</a>
        <a href="/quiz/" class="nav-cta">Where Should I Start? →</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/img/logo.png" alt="Mobile1st" height="32" class="footer-logo" />
          <p>Digital Product Growth for e-commerce brands doing $5M–$100M online.</p>
        </div>
        <div class="footer-links">
          <a href="/#what-we-do">What We Do</a>
          <a href="/#products">Products &amp; Pricing</a>
          <a href="/#results">Results</a>
          <a href="/#fit">Who We Work With</a>
          <a href="/news/">Director's Cut</a>
        </div>
        <div class="footer-cta">
          <p>Ready to find your revenue leaks?</p>
          <a href="/quiz/" class="btn btn-primary">Where Should I Start? →</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {{ "" | currentYear }} Mobile1st. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Booking Modal -->
  <div id="booking-modal" class="booking-modal-overlay" role="dialog" aria-modal="true" aria-label="Book a time to talk">
    <div class="booking-modal">
      <div class="booking-modal-header">
        <h2>Book a Time to Talk</h2>
        <button class="booking-modal-close" aria-label="Close">&times;</button>
      </div>
      <!-- Google Calendar Appointment Scheduling begin -->
      <iframe data-src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ17zgsYfWZ2Wd4knXkXBfCtc1Iz8xpg8UwQ8v04yrIfOyiw24yQpQT_IQWYSkI2GvWs1ekTjM_Z?gv=true" width="100%" height="600" frameborder="0"></iframe>
      <!-- end Google Calendar Appointment Scheduling -->
    </div>
  </div>

  <!-- Podcast Guest Modal -->
  <div id="podcast-modal" class="booking-modal-overlay" role="dialog" aria-modal="true" aria-label="Apply to be a podcast guest">
    <div class="booking-modal">
      <div class="booking-modal-header">
        <h2>Apply to Be a Guest</h2>
        <button class="booking-modal-close" aria-label="Close">&times;</button>
      </div>
      <!-- Google Calendar Appointment Scheduling begin -->
      <iframe data-src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ3c_NZNJoZsKaaX9dU_JrxaZlGsWSHrv8b4HU7PZXIRp_8UzHbVW3ZNx7CEy6ofKlSjyYiily12?gv=true" style="border: 0" width="100%" height="600" frameborder="0"></iframe>
      <!-- end Google Calendar Appointment Scheduling -->
    </div>
  </div>

  <script src="/js/nav.js"></script>
</body>
</html>
