---
layout: base.njk
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "PodcastEpisode",
  "name": {{ episode.title | dump | safe }},
  "description": {{ episode.plainDescription | dump | safe }},
  "datePublished": "{{ episode.date }}",
  "url": "https://mobile1st.com/podcast/{{ episode.slug }}/",
  {% if episode.image %}"image": {{ episode.image | dump | safe }},{% endif %}
  {% if episode.duration %}"timeRequired": "PT{{ episode.duration | durationToSeconds }}S",{% endif %}
  "associatedMedia": {
    "@type": "MediaObject",
    "contentUrl": {{ episode.audioUrl | dump | safe }}
  },
  "actor": {
    "@type": "Person",
    "name": "Justin Aronstein",
    "url": "https://mobile1st.com/about/"
  },
  "partOfSeries": {
    "@type": "PodcastSeries",
    "name": "Checkin to Checkout",
    "url": "https://mobile1st.com/podcast/",
    "image": "https://mobile1st.com/img/og-default.png",
    "author": {
      "@type": "Person",
      "name": "Justin Aronstein",
      "url": "https://mobile1st.com/about/"
    }
  }
}
</script>
{% if episode.audioType === "video/mp4" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": {{ episode.title | dump | safe }},
  "description": {{ episode.plainDescription | dump | safe }},
  "thumbnailUrl": {{ episode.ogImage | dump | safe }},
  "uploadDate": "{{ episode.date }}",
  "contentUrl": {{ episode.audioUrl | dump | safe }},
  "publisher": {
    "@type": "Organization",
    "name": "Mobile1st",
    "logo": {
      "@type": "ImageObject",
      "url": "https://mobile1st.com/img/logo.png"
    }
  }
}
</script>
{% endif %}
<div class="podcast-episode-page">

  <!-- Video player: full-width, above the fold -->
  {% if episode.audioType === "video/mp4" and episode.audioUrl %}
  <div class="podcast-hero-player">
    <div class="podcast-hero-player__inner">
      <video
        controls
        preload="metadata"
        class="podcast-video"
        {% if episode.image %}poster="{{ episode.image }}"{% endif %}
      >
        <source src="{{ episode.audioUrl }}" type="video/mp4">
        Your browser does not support the video element.
      </video>
    </div>
  </div>
  {% endif %}

  <div class="container">

    <a href="/podcast/" class="post-back">← All Episodes</a>

    <div class="podcast-episode__header">
      {% if episode.image %}
      <img class="podcast-episode__img" src="{{ episode.image }}" alt="{{ episode.title }}" width="160" height="160" />
      {% endif %}
      <div class="podcast-episode__header-text">
        <div class="podcast-episode__meta">
          {% if episode.season %}<span class="episode-badge">Season {{ episode.season }}</span>{% endif %}
          {% if episode.episodeNum %}<span class="episode-badge">Episode {{ episode.episodeNum }}</span>{% endif %}
          {% if episode.readableDate %}<span class="episode-meta-date">{{ episode.readableDate }}</span>{% endif %}
          {% if episode.duration %}<span class="episode-meta-sep">·</span><span class="episode-meta-duration">{{ episode.duration }}</span>{% endif %}
        </div>
        <h1 class="podcast-episode__title">{{ episode.title }}</h1>
      </div>
    </div>

    <!-- Fallback players for non-video episodes -->
    {% if episode.audioType !== "video/mp4" %}
      {% if episode.castosEpisodeId %}
      <div class="podcast-player">
        <iframe
          src="https://6838ae27d7d6e1-61780196.castos.com/player/{{ episode.castosEpisodeId }}"
          width="100%"
          height="150"
          frameborder="0"
          scrolling="no"
          title="{{ episode.title }}"
        ></iframe>
      </div>
      {% elif episode.audioUrl %}
      <div class="podcast-player podcast-player--native">
        <audio controls preload="metadata" class="podcast-audio">
          <source src="{{ episode.audioUrl }}" type="{{ episode.audioType }}">
          Your browser does not support the audio element.
        </audio>
      </div>
      {% endif %}
    {% endif %}

    <!-- Listen On -->
    <div class="podcast-listen-on">
      <span class="podcast-listen-on__label">Listen on:</span>
      {% include "components/podcast-platforms.njk" %}
    </div>

    <!-- Episode Description -->
    {% if episode.description %}
    <div class="podcast-episode__description">
      {{ episode.description | autolink | safe }}
    </div>
    {% endif %}

    <!-- Transcript -->
    <div class="podcast-episode__transcript">
      <h2 class="podcast-transcript__heading">Transcript</h2>
      {% if podcastTranscripts[episode.slug] %}
      <div class="transcript-body">
        {{ podcastTranscripts[episode.slug] | safe }}
      </div>
      {% else %}
      <p class="transcript-placeholder">Transcript not yet available for this episode. To add one, create <code>src/_data/transcripts/{{ episode.slug }}.html</code>.</p>
      {% endif %}
    </div>

    <div class="podcast-episode__footer">
      <a href="/podcast/" class="btn btn-outline-dark">← Back to All Episodes</a>
      <button class="btn btn-outline-dark" data-podcast-modal>Apply to Be a Guest →</button>
    </div>

    {% set relatedEpisodes = podcast.episodes | getRelatedEpisodes(episode.slug, 3) %}
    {% if relatedEpisodes.length > 0 %}
    <section class="related-posts" aria-label="More episodes">
      <h2 class="related-posts__heading">More Episodes</h2>
      <ul class="related-posts__list">
        {% for ep in relatedEpisodes %}
        <li class="related-posts__item">
          <a href="/podcast/{{ ep.slug }}/" class="related-posts__link related-posts__link--episode">
            {% if ep.image %}<img src="{{ ep.image }}" alt="{{ ep.title }}" class="related-posts__ep-img" width="64" height="64" />{% endif %}
            <span class="related-posts__ep-text">
              <span class="related-posts__title">{{ ep.title }}</span>
              {% if ep.plainDescription %}<span class="related-posts__desc">{{ ep.plainDescription | truncate(120) }}</span>{% endif %}
            </span>
          </a>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

  </div>
</div>
